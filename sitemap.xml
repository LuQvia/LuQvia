/* LuQvia 8 Pro Sample Pages */
:root{
  --bg:#080d13;--bg2:#101923;--panel:#111b27;--ink:#f8f2e8;--muted:#a9b4c1;
  --line:rgba(255,255,255,.12);--line2:rgba(200,164,93,.32);
  --gold:#c8a45d;--gold2:#e7ca83;--green:#06c755;--red:#d86b5d;
  --radius:24px;--shadow:0 24px 80px rgba(0,0,0,.32);--container:1160px;
}
*{box-sizing:border-box}html{scroll-behavior:smooth}
body{margin:0;background:radial-gradient(circle at 85% 5%,rgba(200,164,93,.12),transparent 28%),radial-gradient(circle at 8% 45%,rgba(125,167,217,.08),transparent 28%),var(--bg);color:var(--ink);font-family:"Noto Sans JP",system-ui,sans-serif;line-height:1.85;letter-spacing:.02em}
a{color:inherit;text-decoration:none}.container{width:min(calc(100% - 40px),var(--container));margin:auto}
.header{position:sticky;top:0;z-index:50;background:rgba(8,13,19,.86);backdrop-filter:blur(18px);border-bottom:1px solid var(--line)}
.header-inner{min-height:74px;display:flex;align-items:center;gap:22px}.logo{display:flex;align-items:center;gap:12px;margin-right:auto}
.logo-mark{width:44px;height:44px;border-radius:16px;display:grid;place-items:center;color:#080d13;background:linear-gradient(135deg,var(--gold),var(--gold2));font-family:"Shippori Mincho",serif;font-weight:900;font-size:1.25rem;box-shadow:0 10px 30px rgba(200,164,93,.25)}
.logo strong{display:block;line-height:1.1}.logo small{display:block;color:var(--muted);font-size:.72rem;margin-top:2px}
.nav{display:flex;gap:17px;color:var(--muted);font-size:.86rem}.nav a:hover{color:var(--gold)}
.header-cta{padding:10px 18px;border-radius:999px;background:var(--gold);color:#080d13;font-weight:900}
.hero{padding:104px 0 88px;position:relative;overflow:hidden}.hero:before{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(8,13,19,.98),rgba(8,13,19,.76),rgba(8,13,19,.98)),radial-gradient(circle at 75% 35%,rgba(200,164,93,.2),transparent 32%);pointer-events:none}
.hero-grid{position:relative;display:grid;grid-template-columns:1.08fr .92fr;gap:56px;align-items:center}
.eyebrow{margin:0 0 14px;color:var(--gold);font-weight:900;font-size:.78rem;letter-spacing:.16em;text-transform:uppercase}
h1,h2{font-family:"Shippori Mincho","Noto Sans JP",serif;line-height:1.23;letter-spacing:.01em}h1{font-size:clamp(2.32rem,5vw,4.8rem);margin:0 0 24px}h2{font-size:clamp(1.8rem,3vw,3.15rem);margin:0 0 18px}h3,p{margin-top:0}
.lead{font-size:1.06rem;color:var(--muted);max-width:780px}.notice{display:inline-flex;margin:16px 0 0;padding:9px 13px;border-radius:999px;border:1px solid var(--line2);background:rgba(200,164,93,.08);color:var(--gold2);font-size:.82rem;font-weight:800}
.actions{display:flex;flex-wrap:wrap;gap:12px;margin:34px 0 20px}.btn{display:inline-flex;min-height:54px;align-items:center;justify-content:center;padding:0 24px;border-radius:999px;font-weight:900;transition:.2s transform,.2s opacity}.btn:hover{transform:translateY(-1px);opacity:.92}
.primary{background:var(--gold);color:#080d13}.line{background:var(--green);color:white}.secondary{border:1px solid var(--line);background:rgba(255,255,255,.07)}
.tags{display:flex;flex-wrap:wrap;gap:10px}.tags span{padding:8px 12px;border-radius:999px;background:rgba(255,255,255,.06);border:1px solid var(--line);color:var(--muted);font-size:.84rem}
.visual{position:relative;min-height:470px}.browser{position:absolute;inset:0 0 64px 0;border:1px solid var(--line);border-radius:32px;background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.04));box-shadow:var(--shadow);overflow:hidden}
.browser-top{height:48px;border-bottom:1px solid var(--line);display:flex;align-items:center;gap:8px;padding:0 18px;background:rgba(255,255,255,.04)}.dot{width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,.28)}
.mock{padding:30px;display:grid;gap:18px}.mock-hero{height:132px;border-radius:22px;background:linear-gradient(135deg,rgba(200,164,93,.28),rgba(125,167,217,.14));border:1px solid var(--line2);padding:22px}.mock-hero strong{font-family:"Shippori Mincho",serif;font-size:1.45rem}
.mock-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}.mock-card{height:82px;border-radius:18px;background:rgba(255,255,255,.07);border:1px solid var(--line);padding:14px;color:var(--muted);font-size:.86rem}
.route-chip{display:flex;align-items:center;gap:8px;flex-wrap:wrap}.route-chip span{padding:7px 10px;border-radius:999px;background:rgba(200,164,93,.12);color:var(--gold);font-size:.78rem;font-weight:900}.route-chip i{width:18px;height:1px;background:var(--gold)}
.float{position:absolute;right:16px;bottom:0;width:310px;padding:24px;border:1px solid var(--line2);border-radius:24px;background:rgba(17,27,39,.84);box-shadow:var(--shadow);backdrop-filter:blur(14px)}.float strong{display:block;color:var(--gold2);font-size:1.35rem}.float span{color:var(--muted);font-size:.9rem}
.section{padding:88px 0}.muted{background:rgba(16,25,35,.78)}.heading{max-width:860px;margin-bottom:42px}.heading p,.card p,.persona p,.faq p,.flow p,.price li,.leadbox li{color:var(--muted)}
.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.grid2{display:grid;grid-template-columns:repeat(2,1fr);gap:22px}
.card,.persona,.price,.faq details,.leadbox{border:1px solid var(--line);border-radius:var(--radius);background:rgba(255,255,255,.055);box-shadow:var(--shadow)}.card{padding:28px}
.num{display:inline-grid;place-items:center;width:42px;height:42px;border-radius:14px;background:rgba(200,164,93,.13);color:var(--gold);font-weight:900;margin-bottom:14px}
.split{display:grid;grid-template-columns:.9fr 1.1fr;gap:48px;align-items:start}.persona{padding:28px;position:relative;overflow:hidden}.persona:before{content:"";position:absolute;right:-45px;top:-45px;width:160px;height:160px;border-radius:50%;background:rgba(200,164,93,.09)}
.table{border:1px solid var(--line);border-radius:28px;overflow:hidden;box-shadow:var(--shadow)}.row{display:grid;grid-template-columns:.78fr 1fr 1fr}.row>div{padding:18px 20px;border-bottom:1px solid var(--line);border-right:1px solid var(--line)}.row>div:last-child{border-right:none;color:var(--gold2);font-weight:800}.row:last-child>div{border-bottom:none}.head{background:rgba(200,164,93,.13);font-weight:900}
.beforeafter{display:grid;grid-template-columns:1fr 1fr;gap:22px}.ba{border-radius:28px;border:1px solid var(--line);background:rgba(255,255,255,.055);overflow:hidden;box-shadow:var(--shadow)}.ba h3{padding:20px 24px;margin:0;border-bottom:1px solid var(--line)}.ba.before h3{color:#f3b0a8}.ba.after h3{color:var(--gold2)}.ba ul{padding:8px 30px 28px;color:var(--muted)}.ba li{margin:10px 0}
.flow{display:grid;gap:14px}.flow div{display:grid;grid-template-columns:70px 220px 1fr;gap:18px;align-items:center;padding:22px;border:1px solid var(--line);border-radius:20px;background:rgba(255,255,255,.055)}.flow span{display:grid;place-items:center;width:46px;height:46px;border-radius:16px;background:var(--gold);color:#080d13;font-weight:900}.flow h3,.flow p{margin:0}
.prices{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}.price{padding:30px}.price>p{color:var(--gold);font-weight:900}.price strong{display:block;color:var(--gold2);font-size:1.82rem;margin:16px 0}.price.featured{border-color:rgba(200,164,93,.55);background:rgba(200,164,93,.08);transform:translateY(-8px)}
.checks{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}.check{padding:18px;border-radius:18px;border:1px solid var(--line);background:rgba(255,255,255,.05);color:var(--muted)}.check strong{display:block;color:var(--ink)}
.leadbox{padding:34px;background:linear-gradient(135deg,rgba(200,164,93,.1),rgba(255,255,255,.04))}.leadbox-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px}
.faq{display:grid;gap:12px}.faq summary{padding:20px 24px;cursor:pointer;font-weight:900}.faq p{padding:0 24px 22px}
.final{background:radial-gradient(circle at 86% 20%,rgba(200,164,93,.2),transparent 32%),#05080d}.final-box{display:grid;grid-template-columns:1fr auto;gap:30px;align-items:center;border:1px solid var(--line2);border-radius:34px;padding:38px;background:rgba(255,255,255,.055);box-shadow:var(--shadow)}.final-box p{color:var(--muted)}.final-actions{display:flex;gap:12px;flex-wrap:wrap;justify-content:flex-end}
.fixed-cta{position:fixed;right:18px;bottom:18px;display:flex;gap:8px;z-index:60}.fixed-cta .btn{min-height:46px;padding:0 16px;box-shadow:var(--shadow)}
.footer{padding:38px 0 100px;border-top:1px solid var(--line);color:var(--muted)}.sample-nav{padding:22px 0;border-bottom:1px solid var(--line);background:rgba(255,255,255,.03)}.sample-nav .container{display:flex;gap:10px;flex-wrap:wrap}.sample-nav a{padding:8px 12px;border-radius:999px;background:rgba(255,255,255,.06);border:1px solid var(--line);color:var(--muted);font-size:.85rem}
@media(max-width:1020px){.nav{display:none}.hero-grid,.split,.final-box,.leadbox-grid{grid-template-columns:1fr}.grid3,.prices,.checks{grid-template-columns:1fr 1fr}.row{grid-template-columns:1fr}.beforeafter{grid-template-columns:1fr}.flow div{grid-template-columns:1fr}.price.featured{transform:none}}
@media(max-width:640px){.container{width:min(calc(100% - 28px),var(--container))}.header-cta{display:none}.hero,.section{padding:68px 0}.actions{display:grid}.btn{width:100%}.visual{min-height:420px}.float{left:16px;right:16px;width:auto}.grid3,.grid2,.prices,.checks{grid-template-columns:1fr}.fixed-cta{left:12px;right:12px}.fixed-cta .btn{flex:1;width:auto;font-size:.86rem}}


.sample-image-wrap{
  margin-top:28px;
  border:1px solid var(--line2);
  border-radius:30px;
  overflow:hidden;
  box-shadow:var(--shadow);
  background:rgba(255,255,255,.055);
}
.sample-image-wrap img{
  width:100%;
  display:block;
}
.sample-preview{
  margin-bottom:18px;
  border:1px solid var(--line);
  border-radius:18px;
  overflow:hidden;
  background:rgba(255,255,255,.04);
}
.sample-preview img{
  width:100%;
  aspect-ratio:16/9;
  object-fit:cover;
  display:block;
}
.browser-image{
  padding:22px;
}
.browser-image img{
  width:100%;
  border-radius:18px;
  border:1px solid var(--line);
  aspect-ratio:16/9;
  object-fit:cover;
}


/* v3 self-check improvements */
:focus-visible{
  outline:3px solid var(--gold2);
  outline-offset:3px;
}
.card .actions{
  margin-top:18px;
}
.sample-preview img{
  transition:.25s transform;
}
.card:hover .sample-preview img{
  transform:scale(1.02);
}
.sample-image-caption{
  padding:14px 18px;
  color:var(--muted);
  font-size:.9rem;
  border-top:1px solid var(--line);
  background:rgba(255,255,255,.035);
}
.page-links{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-top:22px;
}
.page-links a{
  padding:9px 13px;
  border:1px solid var(--line);
  border-radius:999px;
  color:var(--muted);
  background:rgba(255,255,255,.05);
}
.page-links a:hover{
  color:var(--gold);
  border-color:var(--line2);
}
.audit-badge{
  display:inline-flex;
  align-items:center;
  gap:8px;
  margin-top:12px;
  padding:8px 12px;
  border:1px solid var(--line2);
  border-radius:999px;
  background:rgba(200,164,93,.08);
  color:var(--gold2);
  font-size:.82rem;
  font-weight:900;
}
@media(max-width:640px){
  .sample-preview img{
    aspect-ratio: 16/10;
  }
  .sample-image-wrap{
    border-radius:20px;
  }
  .browser-image{
    padding:14px;
  }
  .mock-card{
    height:auto;
    min-height:70px;
  }
  .sample-nav .container{
    overflow-x:auto;
    flex-wrap:nowrap;
    padding-bottom:4px;
  }
  .sample-nav a{
    white-space:nowrap;
  }
}
@media (prefers-reduced-motion: reduce){
  *{
    scroll-behavior:auto!important;
    transition:none!important;
  }
}


/* v4 mobile UI */
body{padding-bottom:96px}
.mobile-only{display:none}
.desktop-only{display:block}
.mobile-menu-btn{display:none;width:46px;height:46px;margin-left:auto;border:1px solid var(--line);border-radius:14px;background:rgba(255,255,255,.06);align-items:center;justify-content:center;flex-direction:column;gap:5px;cursor:pointer}
.mobile-menu-btn span{display:block;width:18px;height:2px;background:var(--ink);border-radius:999px}
.mobile-drawer{position:fixed;top:0;right:0;bottom:0;width:min(88vw,390px);z-index:120;transform:translateX(104%);transition:transform .28s ease}
.mobile-drawer.open{transform:translateX(0)}
.mobile-drawer-inner{height:100%;overflow:auto;background:linear-gradient(180deg,#0b1118,#121d29);border-left:1px solid var(--line2);box-shadow:-20px 0 60px rgba(0,0,0,.35);padding:22px 18px 34px}
.mobile-drawer-head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:18px}
.mobile-drawer-head strong{font-family:"Shippori Mincho",serif;color:var(--gold2);font-size:1.1rem}
.mobile-drawer-close{width:40px;height:40px;border:none;border-radius:12px;background:rgba(255,255,255,.08);color:var(--ink);font-size:1.45rem;cursor:pointer}
.mobile-drawer-actions{display:grid;gap:10px;margin-bottom:18px}
.mobile-drawer-actions .btn{width:100%}
.mobile-drawer-nav,.mobile-drawer-links{display:grid;gap:10px}
.mobile-drawer-nav{margin-bottom:18px}
.mobile-drawer-nav a,.mobile-drawer-links a{padding:13px 14px;border:1px solid var(--line);border-radius:16px;background:rgba(255,255,255,.045);color:var(--ink)}
.drawer-backdrop{position:fixed;inset:0;z-index:110;background:rgba(0,0,0,.45);opacity:0;pointer-events:none;transition:.25s opacity}
.drawer-backdrop.show{opacity:1;pointer-events:auto}
.mobile-quicknav{position:sticky;top:74px;z-index:45;background:rgba(8,13,19,.94);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}
.mobile-quicknav-track{display:flex;gap:10px;overflow:auto;padding:12px 14px;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.mobile-quicknav-track::-webkit-scrollbar{display:none}
.mobile-quicknav a{white-space:nowrap;padding:10px 14px;border-radius:999px;border:1px solid var(--line);background:rgba(255,255,255,.05);color:var(--muted);font-size:.84rem}
.mobile-summary{padding:18px 0 10px}
.mobile-summary-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.mobile-summary-grid article{padding:14px 12px;border-radius:18px;border:1px solid var(--line);background:rgba(255,255,255,.05);box-shadow:var(--shadow)}
.mobile-summary-grid strong{display:block;color:var(--gold2);font-size:.95rem;margin-bottom:6px}
.mobile-summary-grid span{display:block;color:var(--muted);font-size:.78rem;line-height:1.5}
.mobile-top-cta{padding:12px 0 0}
.mobile-top-cta-box{display:grid;gap:10px}
.mobile-top-cta-box .btn{width:100%}
.sample-nav{position:sticky;top:74px;z-index:44}
@media(max-width:1020px){
  .mobile-menu-btn{display:inline-flex}
  .mobile-only{display:block}
  .desktop-only{display:none}
  .header-inner{min-height:68px;gap:12px}
  .logo strong{font-size:.98rem}
  .logo small{font-size:.68rem}
  .hero{padding:72px 0 48px}
  .hero-grid{gap:22px}
  .visual{min-height:340px}
  .browser{position:relative;inset:auto}
  .float{position:relative;margin-top:14px;right:auto;bottom:auto;width:auto}
  .grid3,.grid2,.prices,.checks{grid-template-columns:1fr}
  .card,.persona,.price,.leadbox{border-radius:20px}
  .sample-preview{border-radius:16px}
  .page-links{overflow:auto;flex-wrap:nowrap;padding-bottom:4px;scrollbar-width:none}
  .page-links::-webkit-scrollbar{display:none}
  .page-links a{white-space:nowrap}
}
@media(max-width:640px){
  body{padding-bottom:108px}
  .container{width:min(calc(100% - 24px),var(--container))}
  .header-inner{min-height:64px}
  .logo{gap:10px}
  .logo-mark{width:38px;height:38px;border-radius:12px;font-size:1.05rem}
  .header-cta{display:none}
  .sample-nav{top:64px}
  .mobile-quicknav{top:64px}
  .sample-nav .container{gap:8px;padding:10px 0 6px}
  .sample-nav a{font-size:.78rem;padding:8px 11px}
  h1{font-size:clamp(2rem,9vw,2.7rem);margin-bottom:18px}
  h2{font-size:clamp(1.45rem,7vw,2rem);margin-bottom:12px}
  .lead{font-size:.95rem;line-height:1.75}
  .notice,.audit-badge{font-size:.75rem;line-height:1.45}
  .actions{gap:10px;margin:24px 0 16px}
  .btn{min-height:50px;padding:0 18px;font-size:.95rem}
  .tags{gap:8px}
  .tags span{font-size:.76rem;padding:7px 10px}
  .browser{border-radius:22px}
  .browser-top{height:40px;padding:0 14px}
  .browser-image{padding:12px}
  .browser-image img{border-radius:14px}
  .mock{padding:16px;gap:12px}
  .mock-hero{height:auto;min-height:110px;border-radius:18px;padding:16px}
  .mock-hero strong{font-size:1.15rem}
  .mock-grid{grid-template-columns:1fr 1fr;gap:10px}
  .mock-card{padding:12px;border-radius:14px;font-size:.78rem}
  .visual{min-height:unset}
  .float{padding:18px;border-radius:18px}
  .section{padding:56px 0}
  .heading{margin-bottom:26px}
  .card,.persona,.price,.faq details,.leadbox{padding:20px;border-radius:18px}
  .price strong{font-size:1.6rem}
  .sample-image-wrap{margin-top:18px}
  .sample-image-caption{padding:12px 14px;font-size:.8rem;line-height:1.55}
  .mobile-summary{padding:14px 0 4px}
  .mobile-summary-grid{grid-template-columns:1fr}
  .mobile-summary-grid article{padding:14px}
  .table{border-radius:20px;overflow:visible;border:none;box-shadow:none}
  .table .row.head{display:none}
  .table .row{display:grid;grid-template-columns:1fr;gap:10px;margin-bottom:12px;padding:14px;border:1px solid var(--line);border-radius:18px;background:rgba(255,255,255,.055);box-shadow:var(--shadow)}
  .table .row>div{border:none;padding:0}
  .table .row>div::before{content:attr(data-label);display:block;margin-bottom:6px;color:var(--gold2);font-size:.72rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase}
  .flow{gap:10px}
  .flow div{grid-template-columns:1fr;gap:10px;padding:18px;border-radius:18px}
  .flow span{width:42px;height:42px;border-radius:14px}
  .beforeafter{gap:14px}
  .ba{border-radius:20px}
  .ba h3{padding:16px 18px}
  .ba ul{padding:8px 22px 20px}
  .checks{gap:10px}
  .check{padding:14px;border-radius:16px;font-size:.92rem}
  .leadbox-grid{grid-template-columns:1fr}
  .faq summary{padding:16px 18px;line-height:1.5}
  .faq p{padding:0 18px 18px;font-size:.92rem}
  .final-box{grid-template-columns:1fr;gap:18px;padding:24px 18px;border-radius:24px}
  .final-actions{justify-content:stretch}
  .final-actions .btn{width:100%}
  .footer{padding:30px 0 110px}
  .fixed-cta{left:10px;right:10px;bottom:10px;gap:8px;display:grid;grid-template-columns:1fr 1fr;padding:10px;border-radius:18px;background:rgba(8,13,19,.92);border:1px solid var(--line);backdrop-filter:blur(16px)}
  .fixed-cta .btn{min-height:46px;padding:0 10px;font-size:.84rem;border-radius:14px;box-shadow:none}
}


/* v5 final mobile LP tuning */
.mobile-lp-anchor{position:relative}
.lp-section-label{display:inline-flex;margin-bottom:12px;padding:6px 10px;border:1px solid var(--line2);border-radius:999px;color:var(--gold2);background:rgba(200,164,93,.08);font-size:.74rem;font-weight:900;letter-spacing:.08em}
.mobile-action-band{display:none}
@media(max-width:820px){
  .hero{padding-top:58px}
  .hero .actions{position:relative;z-index:2}
  .sample-preview img,.browser-image img,.sample-image-wrap img{max-height:520px;object-fit:cover}
  .grid3 .card{min-height:auto}
}
@media(max-width:640px){
  body.mobile-ui-ready{font-size:15px}
  .hero{padding-top:48px;padding-bottom:38px}
  .hero:before{background:linear-gradient(180deg,rgba(8,13,19,.98),rgba(8,13,19,.82),rgba(8,13,19,.98)),radial-gradient(circle at 90% 5%,rgba(200,164,93,.2),transparent 35%)}
  .hero-grid{gap:18px}
  .hero .eyebrow{font-size:.72rem;margin-bottom:10px}
  .hero h1{letter-spacing:-.02em}
  .lead{max-width:100%}
  .mobile-top-cta{position:sticky;top:112px;z-index:40;background:linear-gradient(180deg,rgba(8,13,19,.96),rgba(8,13,19,.86));backdrop-filter:blur(14px);padding:10px 0;border-bottom:1px solid var(--line)}
  .mobile-top-cta-box{grid-template-columns:1fr 1fr;gap:8px}
  .mobile-top-cta-box .btn{min-height:44px;border-radius:14px;font-size:.84rem;padding:0 10px}
  .mobile-summary-grid article{display:grid;grid-template-columns:auto 1fr;align-items:center;column-gap:12px}
  .mobile-summary-grid strong{min-width:88px;margin-bottom:0}
  .sample-preview{margin:-2px -2px 16px;border-radius:18px 18px 12px 12px}
  .card .num{width:36px;height:36px;border-radius:12px;margin-bottom:10px;font-size:.86rem}
  .card h3{font-size:1.08rem;line-height:1.45;margin-bottom:8px}
  .card p{font-size:.9rem;line-height:1.7}
  .price{position:relative}
  .price.featured::before{content:"おすすめ";position:absolute;right:16px;top:14px;padding:5px 9px;border-radius:999px;color:#080d13;background:var(--gold2);font-size:.72rem;font-weight:900}
  .mobile-action-band{display:block;padding:18px 0;background:rgba(200,164,93,.07);border-top:1px solid var(--line2);border-bottom:1px solid var(--line2)}
  .mobile-action-band .container{display:grid;gap:10px}
  .mobile-action-band p{color:var(--muted);margin:0;font-size:.88rem}
  .mobile-action-band .btn{width:100%}
}
@media(max-width:430px){
  .container{width:min(calc(100% - 20px),var(--container))}
  h1{font-size:2.05rem}
  h2{font-size:1.55rem}
  .logo small{display:none}
  .tags span:nth-child(n+4){display:none}
  .mobile-quicknav-track{padding-inline:10px}
  .mobile-quicknav a{padding:9px 12px}
  .sample-image-wrap img{max-height:360px}
}
@media(max-width:390px){
  h1{font-size:1.88rem}
  .btn{font-size:.88rem}
  .fixed-cta .btn{font-size:.78rem}
  .mobile-summary-grid strong{min-width:74px;font-size:.85rem}
  .mobile-summary-grid span{font-size:.74rem}
}
@media(max-width:360px){
  .fixed-cta{grid-template-columns:1fr}
  body{padding-bottom:152px}
}


/* v6 all-sample brush-up */
:root{
  --success:#06c755;
  --warning:#e7ca83;
}
body{
  text-rendering:optimizeLegibility;
}
.brush-note{
  display:inline-flex;
  align-items:center;
  gap:8px;
  margin-top:14px;
  padding:9px 13px;
  border-radius:999px;
  border:1px solid var(--line2);
  background:rgba(200,164,93,.08);
  color:var(--gold2);
  font-weight:900;
  font-size:.82rem;
}
.category-strip{
  padding:20px 0;
  border-top:1px solid var(--line);
  border-bottom:1px solid var(--line);
  background:rgba(255,255,255,.035);
}
.category-strip .container{
  display:flex;
  gap:10px;
  overflow:auto;
  scrollbar-width:none;
}
.category-strip .container::-webkit-scrollbar{display:none}
.category-chip{
  white-space:nowrap;
  padding:9px 13px;
  border:1px solid var(--line);
  border-radius:999px;
  color:var(--muted);
  background:rgba(255,255,255,.05);
  font-size:.84rem;
}
.category-chip strong{
  color:var(--gold2);
}
.sample-meta{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:10px;
  margin-top:18px;
}
.sample-meta span{
  padding:10px 12px;
  border:1px solid var(--line);
  border-radius:14px;
  background:rgba(255,255,255,.045);
  color:var(--muted);
  font-size:.82rem;
}
.sample-meta strong{
  display:block;
  color:var(--gold2);
  margin-bottom:2px;
}
.card.is-new{
  border-color:rgba(200,164,93,.42);
}
.card-badge{
  display:inline-flex;
  margin-bottom:10px;
  padding:5px 9px;
  border-radius:999px;
  background:rgba(200,164,93,.14);
  color:var(--gold2);
  font-size:.72rem;
  font-weight:900;
}
.industry-overview{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:18px;
}
.overview-card{
  border:1px solid var(--line);
  border-radius:24px;
  padding:26px;
  background:rgba(255,255,255,.055);
  box-shadow:var(--shadow);
}
.overview-card h3{
  margin-bottom:10px;
}
.overview-card p{
  color:var(--muted);
}
.sales-script{
  border:1px solid var(--line2);
  border-radius:28px;
  padding:30px;
  background:linear-gradient(135deg,rgba(200,164,93,.10),rgba(255,255,255,.04));
  box-shadow:var(--shadow);
}
.sales-script ol{
  margin:0;
  padding-left:22px;
  color:var(--muted);
}
.sales-script li{
  margin:9px 0;
}
.cta-note{
  margin-top:14px;
  color:var(--muted);
  font-size:.9rem;
}
.table .row > div[data-label]::before{
  content:"";
}
@media(max-width:640px){
  .category-strip{
    padding:12px 0;
  }
  .category-chip{
    font-size:.76rem;
    padding:8px 11px;
  }
  .sample-meta{
    grid-template-columns:1fr;
    gap:8px;
  }
  .industry-overview{
    grid-template-columns:1fr;
  }
  .overview-card{
    padding:20px;
    border-radius:18px;
  }
  .sales-script{
    padding:20px;
    border-radius:20px;
  }
  .brush-note{
    font-size:.74rem;
    line-height:1.45;
    border-radius:14px;
  }
  .table .row > div[data-label]::before{
    content:attr(data-label);
    display:block;
    margin-bottom:6px;
    color:var(--gold2);
    font-size:.72rem;
    font-weight:900;
    letter-spacing:.08em;
    text-transform:uppercase;
  }
}


/* v7 lower pages */
.lower-hero{
  padding:84px 0 70px;
  background:
    radial-gradient(circle at 90% 10%,rgba(200,164,93,.16),transparent 30%),
    linear-gradient(180deg,rgba(255,255,255,.035),rgba(255,255,255,0));
}
.breadcrumb{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  color:var(--muted);
  font-size:.84rem;
  margin-bottom:22px;
}
.breadcrumb a{color:var(--gold2)}
.lower-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:18px;
}
.lower-card{
  border:1px solid var(--line);
  border-radius:22px;
  background:rgba(255,255,255,.055);
  padding:24px;
  box-shadow:var(--shadow);
}
.lower-card p,.lower-card li{color:var(--muted)}
.lower-list{
  display:grid;
  gap:12px;
  margin:0;
  padding:0;
  list-style:none;
}
.lower-list li{
  padding:14px 16px;
  border:1px solid var(--line);
  border-radius:16px;
  background:rgba(255,255,255,.045);
}
.lower-cta-box{
  border:1px solid var(--line2);
  border-radius:28px;
  padding:30px;
  background:linear-gradient(135deg,rgba(200,164,93,.12),rgba(255,255,255,.04));
  box-shadow:var(--shadow);
}
.lower-cta-box p{color:var(--muted)}
.lower-page-nav{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-top:24px;
}
.lower-page-nav a{
  padding:9px 13px;
  border:1px solid var(--line);
  border-radius:999px;
  background:rgba(255,255,255,.05);
  color:var(--muted);
  font-size:.85rem;
}
.lower-page-nav a:hover{
  color:var(--gold2);
}
.process-list{
  counter-reset: step;
  display:grid;
  gap:14px;
}
.process-list article{
  position:relative;
  border:1px solid var(--line);
  border-radius:20px;
  background:rgba(255,255,255,.055);
  padding:22px 22px 22px 78px;
  box-shadow:var(--shadow);
}
.process-list article:before{
  counter-increment: step;
  content:counter(step, decimal-leading-zero);
  position:absolute;
  left:22px;
  top:22px;
  width:40px;height:40px;
  display:grid;place-items:center;
  border-radius:14px;
  background:var(--gold);
  color:#080d13;
  font-weight:900;
}
.process-list p{color:var(--muted)}
@media(max-width:640px){
  .lower-hero{padding:56px 0 44px}
  .lower-grid{grid-template-columns:1fr}
  .lower-card{padding:20px;border-radius:18px}
  .lower-cta-box{padding:22px;border-radius:20px}
  .process-list article{
    padding:18px;
  }
  .process-list article:before{
    position:static;
    margin-bottom:12px;
  }
  .lower-page-nav{
    overflow:auto;
    flex-wrap:nowrap;
    padding-bottom:4px;
  }
  .lower-page-nav a{white-space:nowrap}
}
